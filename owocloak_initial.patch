+import 'package:flutter/material.dart';
+
+enum AppMode { simple, advanced }
+
+class HomePage extends StatefulWidget {
+  const HomePage({super.key});
+
+  @override
+  State<HomePage> createState() => _HomePageState();
+}
+
+class _HomePageState extends State<HomePage> {
+  AppMode _mode = AppMode.simple;
+  bool _connected = false;
+  String _strategy = 'Auto';
+
+  @override
+  Widget build(BuildContext context) {
+    final surface = Theme.of(context).colorScheme.surface;
+
+    return Scaffold(
+      backgroundColor: Colors.black,
+      body: SafeArea(
+        child: Padding(
+          padding: const EdgeInsets.all(20),
+          child: Column(
+            crossAxisAlignment: CrossAxisAlignment.stretch,
+            children: [
+              _Header(
+                mode: _mode,
+                onModeChanged: (mode) => setState(() => _mode = mode),
+              ),
+              const SizedBox(height: 20),
+              Expanded(
+                child: Container(
+                  decoration: BoxDecoration(
+                    color: surface.withOpacity(0.14),
+                    borderRadius: BorderRadius.circular(24),
+                    border: Border.all(color: Colors.white12),
+                  ),
+                  child: _mode == AppMode.simple
+                      ? _SimpleMode(
+                          connected: _connected,
+                          strategy: _strategy,
+                          onStrategyChanged: (value) =>
+                              setState(() => _strategy = value),
+                          onToggle: () =>
+                              setState(() => _connected = !_connected),
+                        )
+                      : const _AdvancedMode(),
+                ),
+              ),
+            ],
+          ),
+        ),
+      ),
+    );
+  }
+}
+
+class _Header extends StatelessWidget {
+  final AppMode mode;
+  final ValueChanged<AppMode> onModeChanged;
+
+  const _Header({
+    required this.mode,
+    required this.onModeChanged,
+  });
+
+  @override
+  Widget build(BuildContext context) {
+    return Row(
+      children: [
+        const Text(
+          'OwOCloak',
+          style: TextStyle(fontSize: 24, fontWeight: FontWeight.w700),
+        ),
+        const Spacer(),
+        SegmentedButton<AppMode>(
+          segments: const [
+            ButtonSegment(value: AppMode.simple, label: Text('Простой')),
+            ButtonSegment(value: AppMode.advanced, label: Text('Продвинутый')),
+          ],
+          selected: {mode},
+          onSelectionChanged: (values) => onModeChanged(values.first),
+        ),
+      ],
+    );
+  }
+}
+
+class _SimpleMode extends StatelessWidget {
+  final bool connected;
+  final String strategy;
+  final ValueChanged<String> onStrategyChanged;
+  final VoidCallback onToggle;
+
+  const _SimpleMode({
+    required this.connected,
+    required this.strategy,
+    required this.onStrategyChanged,
+    required this.onToggle,
+  });
+
+  @override
+  Widget build(BuildContext context) {
+    return Center(
+      child: Column(
+        mainAxisAlignment: MainAxisAlignment.center,
+        children: [
+          FilledButton.tonalIcon(
+            onPressed: onToggle,
+            icon: Icon(connected ? Icons.link_off : Icons.lock_open),
+            label: Text(connected ? 'Отключиться' : 'Подключиться'),
+          ),
+          const SizedBox(height: 24),
+          Wrap(
+            spacing: 8,
+            children: ['Auto', 'Games', 'Video', 'Stream']
+                .map(
+                  (value) => ChoiceChip(
+                    label: Text(value),
+                    selected: strategy == value,
+                    onSelected: (_) => onStrategyChanged(value),
+                  ),
+                )
+                .toList(),
+          ),
+        ],
+      ),
+    );
+  }
+}
+
+class _AdvancedMode extends StatelessWidget {
+  const _AdvancedMode();
+
+  @override
+  Widget build(BuildContext context) {
+    return const Padding(
+      padding: EdgeInsets.all(24),
+      child: Center(
+        child: Text(
+          'Advanced mode scaffold\n\nSelf-hosted / Team infrastructure / Security / Split tunneling / Logs',
+          textAlign: TextAlign.center,
+        ),
+      ),
+    );
+  }
+}
